rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /products/{productId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.admin == true;
    }

    match /home/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.admin == true;
    }
  }
}
