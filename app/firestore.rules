rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
        && request.auth.token.admin == true;
    }

    match /siteContent/{documentId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null
        && request.auth.token.admin == true;
    }
  }
}
